# Development Dockerfile for Discord AI Co-Host Bot
FROM python:3.11-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    gcc \
    pkg-config \
    portaudio19-dev \
    libffi-dev \
    libssl-dev \
    libsndfile1 \
    ffmpeg \
    curl \
    git \
    vim \
    && rm -rf /var/lib/apt/lists/*

# Install development tools
RUN pip install --no-cache-dir --upgrade pip debugpy

# Create non-root user for development
RUN useradd --create-home --shell /bin/bash --uid 1000 dev

# Set working directory
WORKDIR /app

# Copy requirements and install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Create necessary directories
RUN mkdir -p /app/logs /app/uploads /app/data/chroma

# Change ownership to dev user
RUN chown -R dev:dev /app

# Switch to dev user
USER dev

# Environment variables for development
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV LOG_LEVEL=DEBUG

# Expose ports
EXPOSE 8000 5678

# Development entrypoint
CMD ["python", "-m", "src.main"]