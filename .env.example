# Required LiveKit Configuration
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# Required OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ADMIN_KEY=your_openai_admin_key_here

# OpenAI Model Configuration
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REASONING_MODEL=gpt-5.4

# ElevenLabs Configuration (optional — enables ElevenLabs as TTS/STT provider)
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_flash_v2_5

# Provider Selection (openai or elevenlabs)
TTS_PROVIDER=openai
STT_PROVIDER=openai

# Web Application Configuration
SECRET_KEY=your_secret_key_here
WEB_PORT=8000
WEB_HOST=0.0.0.0

# Document Processing Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800  # 50MB in bytes
SUPPORTED_FORMATS=pdf,docx,txt,md

# Vector Storage Configuration (ChromaDB)
CHROMA_DB_PATH=./data/chroma

# Optional: Pinecone Configuration (alternative to ChromaDB)
# PINECONE_API_KEY=your_pinecone_api_key
# PINECONE_ENVIRONMENT=your_pinecone_environment

# Context Management Configuration
MAX_CONTEXT_TOKENS=128000
CONTEXT_WINDOW_STRATEGY=sliding
SESSION_TIMEOUT=3600

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Redis Configuration (optional for scaling)
# REDIS_URL=redis://localhost:6379

# Development Settings
ENV=development
DEBUG=true